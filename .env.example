# Windows host project path. Use forward slashes.
# Example: D:/project_magic/cc-connect
HOST_PROJECT_DIR=D:/path/to/your/project

# Windows host Codex home path (read-write bind mount).
# Default example for your machine:
HOST_CODEX_HOME=C:/Users/63576/.codex

# Not required for Codex login-state mode (HOST_CODEX_HOME bind mount).
# Only set this when your cc-connect provider config explicitly uses api_key mapping.
# OPENAI_API_KEY=sk-xxxxx

# Optional: pin Codex CLI version, e.g. 0.122.0
CODEX_CLI_VERSION=latest

# Required on Linux when mounting /var/run/docker.sock into the container.
# Set with: stat -c '%g' /var/run/docker.sock
DOCKER_SOCK_GID=999

# Optional: host root path to expose inside container as /host.
# Linux default is "/" (full host filesystem, high privilege).
# You can set a narrower path such as /www or /data for safer access.
HOST_SERVER_ROOT=/

# Optional timezone inside container.
TZ=Asia/Shanghai
