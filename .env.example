# Windows host project path. Use forward slashes.
# Example: D:/project_magic/cc-connect
HOST_PROJECT_DIR=D:/path/to/your/project

# Windows host Codex home path (read-write bind mount).
# Default example for your machine:
HOST_CODEX_HOME=C:/Users/63576/.codex

# Optional when using ChatGPT/Codex login state in HOST_CODEX_HOME.
# Required only if your cc-connect provider config uses api_key env mapping.
OPENAI_API_KEY=sk-xxxxx

# Optional: pin Codex CLI version, e.g. 0.122.0
CODEX_CLI_VERSION=latest

# Optional timezone inside container.
TZ=Asia/Shanghai
